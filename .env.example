# ═══════════════════════════════════════════════════════
# ThreadPulse — Variables de entorno
# ═══════════════════════════════════════════════════════

# ─── Ya definido — usar desde el día 1 ─────────────────

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude (scoring y drafts)
ANTHROPIC_API_KEY=

# URL pública de la app (ej: http://localhost:3000 en dev)
# Requerida para OAuth y magic links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret para proteger el cron job de Vercel
# Generar con: openssl rand -base64 32
CRON_SECRET=

# ─── Pendiente de decidir — conectar cuando se elija proveedor ─

# Credenciales de Reddit (reddit.com/prefs/apps — tipo "script")
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ThreadPulse/1.0 (by /u/tu_usuario_reddit)

# Credenciales de Twitter/X (developer.x.com → Bearer Token)
TWITTER_BEARER_TOKEN=

# Proveedor de email para alertas (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Alertas <alertas@tudominio.com>

# Reddit: ventana de búsqueda en horas (default 2 — usar con cron cada 1h para ~24/7)
CRON_REDDIT_LOOKBACK_HOURS=2

# Web Push (generar con: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=hello@tudominio.com

# Creem (pagos)
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_PRODUCT_STARTER=prod_5J2miO0aJHOLfGPrJhtCJq
CREEM_PRODUCT_PRO=prod_7Gr4Lke9q8JWONxndhDQL5
CREEM_TEST_MODE=false

# Webhook genérico de prueba (opcional)
# PAYMENT_WEBHOOK_SECRET=
