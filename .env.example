# ═══════════════════════════════════════════════════════
# SubSignal — Variables de entorno
# ═══════════════════════════════════════════════════════

# ─── Ya definido — usar desde el día 1 ─────────────────

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude (scoring y drafts)
ANTHROPIC_API_KEY=

# URL pública de la app (ej: http://localhost:3000 en dev)
# Requerida para OAuth y magic links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret para proteger el cron job de Vercel
# Generar con: openssl rand -base64 32
CRON_SECRET=

# ─── Pendiente de decidir — conectar cuando se elija proveedor ─

# Credenciales de Reddit (método a definir: API oficial vs alternativas)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=

# Credenciales de Twitter/X (método a definir: API oficial vs alternativas)
# TWITTER_BEARER_TOKEN=

# Proveedor de email para alertas (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=SubSignal <alertas@tudominio.com>

# Proveedor de pagos (a definir: Stripe, Lemon Squeezy, Paddle, etc.)
# PAYMENT_PROVIDER=stripe
# PAYMENT_WEBHOOK_SECRET=          # openssl rand -base64 32
# STRIPE_CHECKOUT_ENABLED=false
